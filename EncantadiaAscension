local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew"))()
local tab = library:CreateWindow("Encantadia Ascension")

local RS = game:GetService("ReplicatedStorage")
local CharactersFolder = RS:WaitForChild("Characters")
local RemoteEvents = RS:WaitForChild("RemoteEvents")
local SpawnRemote = RemoteEvents:WaitForChild("Spawn")
local LocalPlayer = game:GetService("Players").LocalPlayer
local Camera = game:GetService("Workspace").CurrentCamera
local StarterGui = game:GetService("StarterGui")

local selectedChar = nil

local function getCharList()
    local list = {}
    for _, char in pairs(CharactersFolder:GetChildren()) do
        table.insert(list, char.Name)
    end
    table.sort(list)
    return list
end

tab:AddList({
    text = "Select Character",
    values = getCharList(),
    callback = function(value)
        selectedChar = value
    end
})

tab:AddButton({
    text = "Deploy",
    callback = function()
        if selectedChar then
            local charObj = CharactersFolder:FindFirstChild(selectedChar)
            if charObj then
                SpawnRemote:FireServer(charObj)
                
                task.spawn(function()
                    local newChar = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                    local humanoid = newChar:WaitForChild("Humanoid", 10)
                    
                    if humanoid then
                        task.wait(0.5)
                        Camera.CameraType = Enum.CameraType.Custom
                        Camera.CameraSubject = humanoid
                    end
                    
                    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
                    local selector = playerGui:FindFirstChild("CharacterSelectorGui")
                    if selector then
                        selector.Enabled = false
                    end
                    
                    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
                    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Hotbar, false)
                    
                    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat, true)
                    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
                    
                    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
                    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Hotbar, false)
                end)
            end
        end
    end
})

library:Init()
